{
  "name": "parking-lot-manager",
  "description": "Full-stack parking lot management system with web and mobile apps",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "cd mobile && npm run start",
    "build": "vite build",
    "build:mobile": "cd mobile && npm run web",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "cd server && python main.py",
    "server:start": "cd server && python main.py",
    "mobile:install": "cd mobile && npm install",
    "mobile:go": "cd mobile && npx expo start --tunnel",
    "start-web": "npm run server & npm run dev",
    "start": "concurrently \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "react": "19.1.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.2",
    "react-router-dom": "^6.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "terser": "^5.17.0",
    "vite": "^7.2.4"
  }
}
